# Jarvis Configuration
# Copy to .env and fill in your keys

# NVIDIA API (free — sign up at https://build.nvidia.com)
# Then go to https://build.nvidia.com/explore/discover to get your API key
NVIDIA_API_KEY=nvapi-xxx-your-key-here

# Or OpenAI / OpenRouter
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
